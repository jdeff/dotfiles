# Machine-/identity-specific settings (name, email, SSH signing key path) live
# in an untracked ~/.gitconfig.local — see gitconfig.local.example. This file
# holds only portable preferences. A later [include] always wins over earlier
# settings, so put it first and let the local file override if needed.
[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main
[pull]
	rebase = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true

[credential]
	# Empty value clears any helper inherited from system config, so osxkeychain
	# is the only one in the list and credentials resolve through it just once.
	helper =
	helper = osxkeychain
# github/gist auth goes through the gh CLI, which returns a token from its own
# keyring storage. The empty helper here drops the inherited osxkeychain so gh
# is the sole helper for these hosts (one fresh token, no second cached copy).
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

# ── git-delta: syntax-highlighted, navigable diffs ───────────────────────
[core]
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true       # use n / N to move between diff sections
	line-numbers = true
	# side-by-side = true # uncomment for split view on wide terminals
[merge]
	conflictStyle = zdiff3
[diff]
	colorMoved = default

[alias]
	co = checkout
	ci = commit
	st = status
	br = branch
	type = cat-file -t
	dump = cat-file -p
	# Compact, graphed history using the `immersion` pretty format below.
	hist = log --pretty=immersion --graph --date=short
	# Same, but first-parent only and no merges — a linear feature view.
	filter = log --pretty=immersion --graph --date=short --first-parent --no-merges

[pretty]
	immersion = %h %ad | %s%d [%an]
