# Machine-/identity-specific settings (name, email, SSH signing key path) live
# in an untracked ~/.gitconfig.local — see gitconfig.local.example. This file
# holds only portable preferences. A later [include] always wins over earlier
# settings, so put it first and let the local file override if needed.
[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main
[pull]
	ff = only
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true

# ── git-delta: syntax-highlighted, navigable diffs ───────────────────────
[core]
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true       # use n / N to move between diff sections
	line-numbers = true
	# side-by-side = true # uncomment for split view on wide terminals
[merge]
	conflictStyle = zdiff3
[diff]
	colorMoved = default
