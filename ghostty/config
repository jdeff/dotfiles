# ~/.config/ghostty/config — Ghostty terminal configuration.

# Follows the macOS system appearance: Lotus (light) / Wave (dark).
theme = light:Kanagawa Lotus,dark:Kanagawa Wave

font-family = Lilex Nerd Font Mono
font-style = Medium
font-size = 14

# Slight transparency + blur (macOS).
background-opacity = 0.96
background-blur = 20

# Roomier window without losing the title bar's drag area.
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = transparent

# Keep scrollback generous; shell already has fzf/zoxide for navigation.
scrollback-limit = 10000

# Don't prompt when closing a surface with a running process.
confirm-close-surface = false

# Clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
selection-clear-on-copy = true
